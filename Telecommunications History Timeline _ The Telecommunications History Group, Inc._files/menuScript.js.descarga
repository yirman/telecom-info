    function myFunction3(menuItem) {
if(window.matchMedia("(hover: hover)").matches && clicked == "no") {
    hovered = "yes";
    if(menuItem=="visit") {
        var x = document.getElementsByClassName("dropbtn")[0];
        x.innerHTML='Visit <i class="fa fa-angle-up"></i>';
    } else if(menuItem=="about") {
        var x = document.getElementsByClassName("dropbtnAbout")[0];
        x.innerHTML='About <i class="fa fa-angle-up"></i>';
    } else if(menuItem=="resources") {
        var x = document.getElementsByClassName("dropbtnResources")[0];
        x.innerHTML='Resources <i class="fa fa-angle-up"></i>';
    }
    }
    }
            
