function myFunction(menuItem) {
    if(menuItem=="visit") {
  var x = document.getElementById("subDropMobile");
  if (x.style.display === "none") {
    x.style.display = "block";
 document.getElementById("linkMobileVisit").innerHTML='Visit <i class="fa fa-angle-up"></i>';
  } else {
    x.style.display = "none";
 document.getElementById("linkMobileVisit").innerHTML='Visit <i class="fa fa-angle-down"></i>';
           var y= document.getElementById("mobileMenu1");
  }
    } else if(menuItem=="about") {
  var x = document.getElementById("subDropMobileAbout");
  if (x.style.display === "none") {
    x.style.display = "block";
 document.getElementById("linkMobileAbout").innerHTML='About <i class="fa fa-angle-up"></i>';
  } else {
    x.style.display = "none";
 document.getElementById("linkMobileAbout").innerHTML='About <i class="fa fa-angle-down"></i>';
           var y= document.getElementById("mobileMenu1");
  }
    } else if(menuItem=="resources") {
  var x = document.getElementById("subDropMobileResources");
  if (x.style.display === "none") {
    x.style.display = "block";
 document.getElementById("linkMobileResources").innerHTML='Resources <i class="fa fa-angle-up"></i>';
  } else {
    x.style.display = "none";
 document.getElementById("linkMobileResources").innerHTML='Resources <i class="fa fa-angle-down"></i>';
           var y= document.getElementById("mobileMenu1");
  }
    }
}
            
